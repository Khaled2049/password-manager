{
  "name": "password-manager",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "cdk",
    "scripts",
    "core",
    "examples"
  ],
  "scripts": {
    "build": "yarn workspaces run build",
    "clean": "yarn workspaces run clean",
    "deploy": "cd cdk && yarn deploy",
    "synth": "cd cdk && yarn synth",
    "example": "cd examples && tsx basic-usage.ts",
    "generate": "tsx scripts/generate-presigned-urls.ts"
  },
  "packageManager": "yarn@1.22.0",
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
